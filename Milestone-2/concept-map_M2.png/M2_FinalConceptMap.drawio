        <mxCell id="iDmIjBZTF_3UvhJtqcMz-50" connectable="0" parent="iDmIjBZTF_3UvhJtqcMz-49" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;fontSize=9;fontStyle=2;" value="characterized using" vertex="1">
