<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/144.0.0.0 Safari/537.36" version="29.4.0">
  <diagram name="Page-1" id="Xehs-OKM3HTLwH_Hx9Nm">
    <mxGraphModel dx="2722" dy="2191" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" background="light-dark(#FFFFFF,#8B8B8B)" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0a30a;fontColor=#000000;strokeColor=#BD7000;fontSize=11;verticalAlign=middle;" value="&lt;b&gt;Core Problem: Uncertain TPT&lt;/b&gt;&lt;br&gt;&lt;i&gt;Task Processing Time (TPT) is a random variable;&lt;br&gt;same task runs differently under different inputs.&lt;br&gt;Deterministic models cause inaccurate offloading.&lt;/i&gt;" vertex="1">
          <mxGeometry height="85" width="270" x="830" y="530" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="&lt;b&gt;D2D Edge Network&lt;/b&gt;&lt;br&gt;&lt;i&gt;N mobile devices (MDs) share CPU resources;&lt;br&gt;each MD offloads tasks to peer devices directly,&lt;br&gt;without going through a base station&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="565" y="20" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="&lt;b&gt;Latency-Sensitive Applications&lt;/b&gt;&lt;br&gt;&lt;i&gt;AR, Visual Relationship Detection (VRD),&lt;br&gt;speech recognition, object detection.&lt;br&gt;Mobile CPU cannot handle these alone.&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="270" x="830" y="-90" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="&lt;b&gt;Hard Deadline τk&lt;/b&gt;&lt;br&gt;&lt;i&gt;Each task type k has a deadline τk.&lt;br&gt;Goal: maximize P(Tfinish ≤ τk), not minimize&lt;br&gt;average delay. Average is not enough!&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="255" x="555" y="270" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="&lt;b&gt;Motivating Example (Paper Fig. 1)&lt;/b&gt;&lt;br&gt;&lt;i&gt;AR deadline=0.6s, Beautycam=1.3s.&lt;br&gt;Both avg TPT=1.2s: existing work drops AR.&lt;br&gt;OffloadBC gives 36%+92% vs 0%+58%.&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="265" x="545" y="140" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;Processing Uncertainty (Root Cause)&lt;/b&gt;&lt;br&gt;&lt;i&gt;VRD with 1 target is 100x faster than with 20.&lt;br&gt;Same code, different input = different runtime.&lt;br&gt;CPU varies 1.6-4.8 GHz across devices.&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="255" x="-220" y="342.5" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;Arrival Uncertainty&lt;/b&gt;&lt;br&gt;&lt;i&gt;AR devices continuously generate image tasks.&lt;br&gt;Inter-arrival times are random and follow&lt;br&gt;a Poisson process with rate λk.&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="255" x="250" y="450" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;[RV] Xproc - Task Processing Time&lt;/b&gt;&lt;br&gt;&lt;i&gt;Modeled as Exponential(u): f(t)=u*exp(-u*t).&lt;br&gt;For VRD: u=0.588 (fitted from 5000 images).&lt;br&gt;Only 30 samples needed for &lt;4% error.&lt;/i&gt;" vertex="1">
          <mxGeometry height="85" width="270" x="1330" y="340" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;[RV] Tinter - Inter-arrival Time&lt;/b&gt;&lt;br&gt;&lt;i&gt;Exponential(lambda_k); arrivals follow Poisson.&lt;br&gt;Tasks arrive one by one, served in order.&lt;br&gt;Assumption: independent inter-arrival times.&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="270" x="1556" y="450" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;[RV] Wq - Queue Waiting Time&lt;/b&gt;&lt;br&gt;&lt;i&gt;Derived RV from M/G/1 dynamics.&lt;br&gt;Depends on both lambda and u.&lt;br&gt;System stable only when u &gt; lambda.&lt;/i&gt;" vertex="1">
          <mxGeometry height="80" width="270" x="1556" y="640" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" value="&lt;b&gt;[RV] Tsojourn = Wq + Xproc + Ttrans&lt;/b&gt;&lt;br&gt;&lt;i&gt;Aggregate completion time RV. If offloaded,&lt;br&gt;add transmission delay: tr = task_size/bandwidth.&lt;br&gt;Must satisfy: P(Tsojourn &lt;= τk) = success.&lt;/i&gt;" vertex="1">
          <mxGeometry height="85" width="270" x="1856" y="872.5" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;Measurement-Based TPT Model&lt;/b&gt;&lt;br&gt;&lt;i&gt;Offline curve fitting on real datasets:&lt;br&gt;VRD=Exponential, Speech=Gamma,&lt;br&gt;Alignment=Gaussian, POS=GEV.&lt;br&gt;Parameters calibrated with only 30 samples.&lt;/i&gt;" vertex="1">
          <mxGeometry height="95" width="270" x="-227.5" y="980" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;M/G/1 Queue Model&lt;/b&gt;&lt;br&gt;&lt;i&gt;Poisson arrivals (M), general service time (G).&lt;br&gt;Generalizes M/M/1 to support any f(t).&lt;br&gt;Completion CDF via Laplace transform:&lt;br&gt;F(t)=L-1{(1-lambda/u)*B(a)*a / (lambda*B(a)+a-lambda)}&lt;/i&gt;" vertex="1">
          <mxGeometry height="95" width="285" x="155" y="810" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" value="&lt;b&gt;Completion Probability Formula&lt;/b&gt;&lt;br&gt;&lt;i&gt;F(t-tr) = 1 - exp(-(uj - lambda_k)*(t-tr))&lt;br&gt;where τeff = τk - tr (time left after transmission).&lt;br&gt;Validated at 97.7% accuracy on real VRD data.&lt;/i&gt;" vertex="1">
          <mxGeometry height="90" width="285" x="822.5" y="870" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="&lt;b&gt;Jensen&#39;s Inequality&lt;/b&gt;&lt;br&gt;&lt;i&gt;E[Cost(T)] &gt;= Cost(E[T]).&lt;br&gt;Avg TPT=1.2s hides that only 58% of&lt;br&gt;Beautycam tasks actually finish on time.&lt;br&gt;Variance is the real risk, not just the mean.&lt;/i&gt;" vertex="1">
          <mxGeometry height="95" width="270" x="830" y="700" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-18" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" value="&lt;b&gt;Non-Cooperative Game G={N, A, P}&lt;/b&gt;&lt;br&gt;&lt;i&gt;Each MD=one player. Strategy: pick offload target.&lt;br&gt;Payoff Pi = sum of completion rates Fij_k.&lt;br&gt;Device i maximizes own Pi given others a-i.&lt;/i&gt;" vertex="1">
          <mxGeometry height="90" width="280" x="1220" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="&lt;b&gt;Potential Game (Theorem 2)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Potential function phi(a) defined over all decisions.&lt;br&gt;Proven: if any device improves Pi, then phi(a)&lt;br&gt;also increases. Guarantees Nash Equilibrium exists.&lt;/i&gt;" vertex="1">
          <mxGeometry height="85" width="280" x="1220" y="1313" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="&lt;b&gt;Congestion Externality&lt;/b&gt;&lt;br&gt;&lt;i&gt;P(A and B both succeed) &lt; P(A)*P(B).&lt;br&gt;When B offloads to same device j, it raises lambda_j,&lt;br&gt;which reduces F(t-tr) for A.&lt;br&gt;Negative probabilistic dependence between users.&lt;/i&gt;" vertex="1">
          <mxGeometry height="90" width="280" x="820" y="1313" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-21" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" value="&lt;b&gt;MATURE Algorithm&lt;/b&gt;&lt;br&gt;&lt;i&gt;Distributed game-based offloading. Each iteration:&lt;br&gt;one MD updates strategy for max completion gain.&lt;br&gt;Converges in at most NK*Dmax2/(Dmin*DeltaD) steps.&lt;br&gt;Improves task completion by 23% vs. baseline.&lt;/i&gt;" vertex="1">
          <mxGeometry height="90" width="280" x="1226" y="1515" as="geometry" />
        </mxCell>
        <mxCell id="iDmIjBZTF_3UvhJtqcMz-22" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="&lt;b&gt;Nash Equilibrium&lt;/b&gt;&lt;br&gt;&lt;i&gt;Stable state reached after finite iterations.&lt;br&gt;No single device can improve its completion rate&lt;br&gt;by unilaterally switching offload target.&lt;br&gt;System self-organizes to global optimum.&lt;/i&gt;" vertex="1">
          <mxGeometry height="85" width="280" x="1226" y="1705" as="geometry" />
        </mxCell>
